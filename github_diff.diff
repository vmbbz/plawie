+++ b/lib/services/local_llm_service.dart
@@ -353,8 +353,14 @@ class LocalLlmService {
 
   Future<bool> _isBinaryInstalled() async {
     try {
+      // Validate the binary is a real ELF executable, not a stub/corrupt file.
+      // A real llama-server binary is 5–15 MB; the old broken download left a
+      // 9-byte GitHub 404 redirect file that passes `test -x` but crashes the OS.
+      // stat -c%s returns the file size in bytes; we require > 1 MB.
       final result = await NativeBridge.runInProot(
-        'test -x /root/.openclaw/bin/llama-server && echo "exists"',
+        'test -x /root/.openclaw/bin/llama-server && '
+        r'[ $(stat -c%s /root/.openclaw/bin/llama-server 2>/dev/null || echo 0) -gt 1048576 ] && '
+        'echo "exists"',
         timeout: 5,
       );
       return result.trim() == 'exists';

commit 7b34cb1a67656d22672183ff24f63b623a642d61
Author: vchat-meme-blip <limeikenji@gmail.com>
Date:   Thu Mar 26 17:59:48 2026 +0200

    fix(llama): replace broken binary download with compile-from-source
    
    llama.cpp never ships Android ARM64 pre-built binaries. The previous
    _compileBinary() downloaded from non-existent GitHub URLs, receiving a
    9-byte 404 redirect that the OS rejected with "not a dynamic executable".
    
    Replace with a 5-stage cmake build inside PRoot Ubuntu:
      1. apt-get install cmake g++ git ninja-build
      2. git clone --depth 1 ggerganov/llama.cpp
      3. cmake configure (LLAMA_NATIVE=OFF for portable ARM64)
      4. cmake --build --target llama-server -j2 (2400s timeout)
      5. install binary, verify --version, remove source tree
    
    Each stage updates UI progress so the user sees meaningful status
    during the 20-40 minute first-run compilation.
    
    Also removes the now-dead _getOptimalBinaryUrl() helper.
    
    Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>

